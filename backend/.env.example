# Copy this file to .env and fill in your key
# Get a FREE Gemini API key (no credit card required) at https://aistudio.google.com/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxx
# Google frequently renames/retires model IDs. If you get a "404 NOT_FOUND"
# error, run `python scripts/list_models.py` and paste a valid name here.
GEMINI_MODEL=gemini-flash-latest
FASTAPI_SECRET_KEY=change-me-to-a-random-string
FRONTEND_ORIGIN=http://localhost:3000
